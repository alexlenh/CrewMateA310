{
  "id": "before_takeoff",
  "name": "Before Takeoff",
  "sound_start": "cabin_takeoff.ogg",
  "sound_end": "ready.ogg",
  "steps": [
    {
      "label": "Autobrake set",
      "read": "(L:A310_AUTOBRAKE_LEVEL)",
      "on": "3 (>L:A310_AUTOBRAKE_LEVEL)",
      "expect": 3
    },
    {
      "label": "Ignition set",
      "read": "(L:A310_eng_ignition_switch)",
      "on": "4 (>L:A310_eng_ignition_switch)",
      "expect": 4
    },
    {
      "label": "Pack 1",
      "read": "(L:A300_PACK1_BUTTON)",
      "on": "{pack1_cmd}",
      "expect": "{pack1_expect}"
    },
    {
      "label": "Pack 2",
      "read": "(L:A300_PACK2_BUTTON)",
      "on": "{pack2_cmd}",
      "expect": "{pack2_expect}"
    },
    {
      "label": "TCAS Set",
      "read": "(L:A310_tcas_mode_pedestal)",
      "on": "2 (>L:A310_tcas_mode_pedestal)",
      "expect": 2
    },
    {
      "label": "Strobes",
      "read": "(L:A310_POTENTIOMETER_24)",
      "on": "0 (>L:A310_POTENTIOMETER_24)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Landing Lights",
      "read": "(L:A310_LANDING_LIGHT_L_SWITCH)",
      "on": "0 (>L:A310_LANDING_LIGHT_L_SWITCH)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Landing Lights",
      "read": "(L:A310_LANDING_LIGHT_R_SWITCH)",
      "on": "0 (>L:A310_LANDING_LIGHT_R_SWITCH)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:A310_TAXI_LIGHTS_SWITCH)",
      "on": "0 (>L:A310_TAXI_LIGHTS_SWITCH)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    }
  ]
}
