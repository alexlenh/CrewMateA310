{
  "id": "after_landing",
  "name": "After Landing",
  "steps": [
    {
      "label": "Engine 1 Anti Ice",
      "read": "(L:A310_ENG_ANTI_ICE1)",
      "on": "{landing_anti_ice_eng1_cmd}",
      "expect": "{landing_anti_ice_eng1_expect}"
    },
    {
      "label": "Engine 2 Anti Ice",
      "read": "(L:A310_ENG_ANTI_ICE2)",
      "on": "{landing_anti_ice_eng2_cmd}",
      "expect": "{landing_anti_ice_eng2_expect}"
    },
    {
      "label": "Ignition set",
      "read": "(L:A310_eng_ignition_switch)",
      "on": "3 (>L:A310_eng_ignition_switch)",
      "expect": 3
    },
    {
      "label": "APU",
      "read": "(L:A310_apu_master_switch)",
      "on": "{landing_apu_master_cmd}",
      "expect": "{landing_apu_master_expect}"
    },
    {
      "label": "APU Start",
      "read": "(L:A310_APU_START_BUTTON)",
      "on": "{landing_apu_start_cmd}",
      "expect": "{landing_apu_start_expect}"
    },

    {
      "label": "Weather radar",
      "read": "(L:A310_WXR_SYS)",
      "on": "1 (>L:A310_WXR_SYS)",
      "expect": 1
    },
    {
      "label": "Pitch trim",
      "read": "(L:ELEV_TRIM_RATIO)",
      "on": "1 (>L:ELEV_TRIM_RATIO)",
      "expect": 1
    },
    {
      "label": "Flaps",
      "read": "(A:FLAPS HANDLE INDEX,Number)",
      "on": "1 (>K:FLAPS_UP)",
      "expect": 0,
      "only_if": {
        "option": "landing.antiIce",
        "one_of": ["off"]
      }
    },
    {
      "label": "Landing Lights",
      "read": "(L:A310_LANDING_LIGHT_L_SWITCH)",
      "on": "0 (>L:A310_LANDING_LIGHT_L_SWITCH)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Landing Lights",
      "read": "(L:A310_LANDING_LIGHT_R_SWITCH)",
      "on": "0 (>L:A310_LANDING_LIGHT_R_SWITCH)",
      "expect": 0,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Strobes",
      "read": "(L:A310_POTENTIOMETER_24)",
      "on": "1 (>L:A310_POTENTIOMETER_24)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:A310_TAXI_LIGHTS_SWITCH)",
      "on": "1 (>L:A310_TAXI_LIGHTS_SWITCH)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    }
  ]
}
