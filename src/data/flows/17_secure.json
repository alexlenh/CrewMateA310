      "expect": 0
    },
    {
      "label": "IRS 2 off",
      "read": "(L:A310_IRS2_STATE)",
      "on": "0 (L:A310_IRS2_STATE)",
      "expect": 0
    },
    {
      "label": "IRS 3 off",
      "read": "(L:A310_IRS3_STATE)",
      "on": "0 (L:A310_IRS3_STATE)",
      "expect": 0
    },
    {
      "label": "Oxy off",
      "read": "(L:A310_OXYGEN_LOW_PRESSURE_SUPPLY)",
