              { "var": "(L:A310_ENG1_ANTI_ICE)", "expected": 1 },
              { "var": "(L:A310_ENG2_ANTI_ICE)", "expected": 1 },
              { "var": "(L:A310_WING_ANTI_ICE)", "expected": 0 }
            ]
          },
          {
            "store_value": "onengwing",
            "expected_response": "on",
            "simvar_checks": [
              { "var": "(L:A310_ENG1_ANTI_ICE)", "expected": 1 },
              { "var": "(L:A310_ENG2_ANTI_ICE)", "expected": 1 },
              { "var": "(L:A310_WING_ANTI_ICE)", "expected": 1 }
