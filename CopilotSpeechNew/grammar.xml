<?xml version="1.0" encoding="UTF-8"?>
<grammar
  version="1.0"
  xml:lang="en-US"
  xmlns="http://www.w3.org/2001/06/grammar"
  tag-format="semantics/1.0"
  root="TOPLEVEL"
>
  <!-- ═══════════════════════════════════════════════════════════════════════════
       TOPLEVEL
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="TOPLEVEL" scope="public">
    <item repeat="0-1">please</item>
    <one-of>
      <item>
        <ruleref uri="#FO_COMMANDS" />
        <tag>out.ActionRuleId="FO_COMMANDS"; out.CmdId=rules.FO_COMMANDS.pid; out.CmdValue=rules.FO_COMMANDS.cval;</tag>
      </item>
      <item>
        <ruleref uri="#FMA_CALLOUTS" />
        <tag>out.ActionRuleId="FMA_CALLOUTS"; out.CmdId=rules.FMA_CALLOUTS.pid; out.CmdValue=rules.FMA_CALLOUTS.cval;</tag>
      </item>
      <item>
        <ruleref uri="#DISCRETE_COMMANDS" />
        <tag>out.ActionRuleId="DISCRETE_COMMANDS"; out.CmdId=rules.DISCRETE_COMMANDS.pid;</tag>
      </item>
    </one-of>
    <item repeat="0-1">please</item>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       FO_COMMANDS  (parameterized — cval carries the numeric value)
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="FO_COMMANDS">
    <one-of>
      <!-- Heading -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <one-of>
          <item>heading</item>
        </one-of>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.pid="1"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- Flight level -->
      <item>
        <item repeat="0-1">set</item>
        <item>flight level</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <item repeat="0-1">pull</item>
        <tag>out.pid="2"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- Altitude feet -->
      <item>
        <item repeat="0-1">set</item>
        <item>altitude</item>
        <ruleref uri="#ALTITUDE_VALUE" />
        <item repeat="0-1">pull</item>
        <tag>out.pid="3"; out.cval=rules.ALTITUDE_VALUE;</tag>
      </item>

      <!-- Speed -->
      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <item>speed</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <item repeat="0-1">knots</item>
        <tag>out.pid="4"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <item>
        <item repeat="0-1">
          <ruleref uri="#VERB" />
        </item>
        <item>qnh</item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item repeat="0-1">set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Altimeter — prefixed "altimeter XXXX [set]" -->
      <item>
        <item>altimeter</item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item repeat="0-1">set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Altimeter — bare "XXX[X] set" -->
      <item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item>set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Fuel kilograms [balanced] -->
      <item>
        <item repeat="0-1">
          <one-of>
            <item>fuel quantity</item>
            <item>fuel</item>
          </one-of>
        </item>
        <ruleref uri="#FUEL_VALUE" />
        <tag>out.fv=rules.FUEL_VALUE;</tag>
        <one-of>
          <item>kilograms</item>
          <item>kilos</item>
        </one-of>
        <one-of>
          <item>balanced<tag>out.pid="9"; out.cval=out.fv;</tag></item>
          <item>
            <tag>out.pid="8"; out.cval=out.fv;</tag>
          </item>
        </one-of>
      </item>

      <!-- Fuel pounds [balanced] -->
      <item>
        <item repeat="0-1">
          <one-of>
            <item>fuel quantity</item>
            <item>fuel</item>
          </one-of>
        </item>
        <ruleref uri="#FUEL_VALUE" />
        <tag>out.fv=rules.FUEL_VALUE;</tag>
        <item>pounds</item>
        <one-of>
          <item>balanced<tag>out.pid="11"; out.cval=out.fv;</tag></item>
          <item>
            <tag>out.pid="10"; out.cval=out.fv;</tag>
          </item>
        </one-of>
      </item>

      <!-- Fuel tons [balanced] -->
      <item>
        <item repeat="0-1">
          <one-of>
            <item>fuel quantity</item>
            <item>fuel</item>
          </one-of>
        </item>
        <ruleref uri="#FUEL_TONS_VALUE" />
        <tag>out.fv=rules.FUEL_TONS_VALUE;</tag>
        <one-of>
          <item>tons</item>
          <item>metric tons</item>
        </one-of>
        <one-of>
          <item>balanced<tag>out.pid="13"; out.cval=out.fv;</tag></item>
          <item>
            <tag>out.pid="12"; out.cval=out.fv;</tag>
          </item>
        </one-of>
      </item>

      <!-- Missed approach altitude — explicit feet -->
      <item>
        <one-of>
          <item>set go around altitude</item>
          <item>set go around</item>
          <item>go around altitude</item>
          <item>go around</item>
        </one-of>
        <ruleref uri="#ALTITUDE_VALUE" />
        <item repeat="0-1">feet</item>
        <tag>out.pid="16"; out.cval=rules.ALTITUDE_VALUE;</tag>
      </item>

      <!-- Missed approach altitude — explicit flight level -->
      <item>
        <one-of>
          <item>set go around altitude</item>
          <item>set go around</item>
          <item>go around altitude</item>
          <item>go around</item>
        </one-of>
        <item>flight level</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.pid="17"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- BARO minimums — "baro four hundred fifty [feet]" → "450" -->
      <item>
        <item>mda</item>
        <ruleref uri="#MINIMUMS_VALUE" />
        <item repeat="0-1">feet</item>
        <item>set</item>
        <tag>out.pid="18"; out.cval=rules.MINIMUMS_VALUE;</tag>
      </item>

      <!-- RADIO minimums — "radio one hundred sixty [feet]" → "160" -->
      <item>
        <item>dh</item>
        <ruleref uri="#MINIMUMS_VALUE" />
        <item repeat="0-1">feet</item>
        <item>set</item>
        <tag>out.pid="19"; out.cval=rules.MINIMUMS_VALUE;</tag>
      </item>

      <!-- PITCH TRIM -->
      <item>
        <ruleref uri="#NUMBERS" />
        <tag>var n1=rules.NUMBERS;</tag>
        <item>point</item>
        <ruleref uri="#NUMBERS" />
        <tag>var n2=rules.NUMBERS;</tag>
        <one-of>
          <item>up<tag>out.cval = n1 + "." + n2;</tag></item>
          <item>down<tag>out.cval = "-" + n1 + "." + n2;</tag></item>
        </one-of>
        <item>set</item>
        <tag>out.pid="20";</tag>
      </item>

      <item>
        <one-of>
          <!-- Path 1: Thousand, Hundred, and Fifty increments -->
          <item>
            <item repeat="0-1">
              <ruleref uri="#ALTV_THOUSANDS" /> thousand
            </item
            >
            <item repeat="0-1">
              <ruleref uri="#ALTV_HUNDREDS" />
            </item>
            <item repeat="0-1">
              fifty <tag>var hasFifty = 50;</tag>
            </item>
          </item>

          <!-- Path 2: Just "zero" -->
          <item>zero <tag>var isZero = true;</tag></item>
        </one-of>
        <item>feet set</item>
        <tag>
          out.pid = "21";
          if (typeof isZero !== 'undefined') {
              out.cval = "0";
          } else {
              var k = rules.ALTV_THOUSANDS ? (parseInt(rules.ALTV_THOUSANDS) * 1000) : 0;
              var h = rules.ALTV_HUNDREDS ? parseInt(rules.ALTV_HUNDREDS) : 0;
              var f = typeof hasFifty !== 'undefined' ? 50 : 0;
              out.cval = (k + h + f).toString();
          }
        </tag>
      </item>
    </one-of>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       FMA_CALLOUTS
       pid always "1". cval = "thrust|vertical|lateral|combined|cat|armed|urgent"
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="FMA_CALLOUTS">
    <one-of>
      <!-- urgent standalones -->
      <!-- compound: optional thrust + vertical/combined/lateral + optional cat + optional armed -->
      <item>
        <tag>out.th=""; out.vt=""; out.lt=""; out.cb=""; out.ct=""; out.ar="";</tag>
        <item repeat="0-1">check</item>
        <item repeat="0-1">
          <ruleref uri="#FMA_THRUST_MODE" />
          <tag>out.th=rules.FMA_THRUST_MODE;</tag>
        </item>
        <one-of>
          <item>
            <ruleref uri="#FMA_COMBINED_MODE" />
            <tag>out.cb=rules.FMA_COMBINED_MODE;</tag>
          </item>
          <item>
            <ruleref uri="#FMA_VERTICAL_MODE" />
            <tag>out.vt=rules.FMA_VERTICAL_MODE;</tag>
            <item repeat="0-1">
              <ruleref uri="#FMA_LATERAL_MODE" />
              <tag>out.lt=rules.FMA_LATERAL_MODE;</tag>
            </item>
          </item>
          <item>
            <ruleref uri="#FMA_LATERAL_MODE" />
            <tag>out.lt=rules.FMA_LATERAL_MODE;</tag>
          </item>
        </one-of>
        <item repeat="0-1">
          <ruleref uri="#FMA_APPROACH_CAT" />
          <tag>out.ct=rules.FMA_APPROACH_CAT;</tag>
        </item>
        <tag>out.pid="1"; out.cval=out.th+"|"+out.vt+"|"+out.lt+"|"+out.cb+"|"+out.ct+"|";</tag>
      </item>

      <!-- thrust only -->
      <item>
        <tag>out.ar="";</tag>
        <ruleref uri="#FMA_THRUST_MODE" />
        <tag>out.th=rules.FMA_THRUST_MODE;</tag>
        <tag>out.pid="1"; out.cval=out.th+"|||||";</tag>
      </item>
    </one-of>
  </rule>

  <!-- FMA column 1: thrust modes -->
  <rule id="FMA_THRUST_MODE">
    <one-of>
      <item>thrust<tag>out="THR";</tag></item>
      <item>profile thrust<tag>out="P. THR";</tag></item>
      <item>speed<tag>out="SPEED";</tag></item>
      <item>mach<tag>out="MACH";</tag></item>
      <item>profile speed<tag>out="P. SPEED";</tag></item>
      <item>profile mach<tag>out="P. MACH";</tag></item>
      <item>retard<tag>out="RTAR";</tag></item>
      <item>thrust latch<tag>out="THR L";</tag></item>
    </one-of>
  </rule>

  <!-- FMA column 2: vertical modes -->
  <rule id="FMA_VERTICAL_MODE">
    <one-of>
      <item>srs<tag>out="SRS";</tag></item>
      <item>alt hold<tag>out="ALT";</tag></item>
      <item>alt star<tag>out="ALT*";</tag></item>
      <item>profile descent<tag>out="P. DES";</tag></item>
      <item>glideslope<tag>out="G/S";</tag></item>
      <item>glideslope star<tag>out="G/S*";</tag></item>
      <item>glideslope capture<tag>out="G/S*";</tag></item>
      <item>profile climb<tag>out="P. CLB";</tag></item>
      <item>profile alt hold<tag>out="P. ALT";</tag></item>
      <item>mach<tag>out="MACH";</tag></item>
      <item>vertical speed<tag>out="V/S";</tag></item>
      <item>speed<tag>out="SPD";</tag></item>
    </one-of>
  </rule>

  <!-- FMA column 3: lateral modes -->
  <rule id="FMA_LATERAL_MODE">
    <one-of>
      <item>runway<tag>out="RWY";</tag></item>
      <item>heading<tag>out="HDG";</tag></item>
      <item>heading select<tag>out="HDG/S";</tag></item>
      <item>nav<tag>out="NAV";</tag></item>
      <item>loc<tag>out="LOC";</tag></item>
      <item>loc star<tag>out="LOC*";</tag></item>
      <item>loc capture<tag>out="LOC*";</tag></item>
      <item>localizer<tag>out="LOC";</tag></item>
      <item>localizer star<tag>out="LOC*";</tag></item>
      <item>localizer capture<tag>out="LOC*";</tag></item>
      <item>v o r<tag>out="VOR";</tag></item>
      <item>v o r capture<tag>out="VOR*";</tag></item>
      <item>v o r star<tag>out="VOR*";</tag></item>
    </one-of>
  </rule>

  <!-- FMA cols 2+3: combined modes -->
  <rule id="FMA_COMBINED_MODE">
    <one-of>
      <item>land<tag>out="LAND";</tag></item>
      <item>flare<tag>out="FLARE";</tag></item>
      <item>roll out<tag>out="ROLL OUT";</tag></item>
      <item>go around<tag>out="GO AROUND";</tag></item>
    </one-of>
  </rule>

  <!-- FMA column 4: approach category -->
  <rule id="FMA_APPROACH_CAT">
    <one-of>
      <item>cat one<tag>out="CAT 1";</tag></item>
      <item>cat two<tag>out="CAT 2";</tag></item>
      <item>cat three single<tag>out="CAT 3 SINGLE";</tag></item>
      <item>cat three dual<tag>out="CAT 3 DUAL";</tag></item>
    </one-of>
  </rule>

