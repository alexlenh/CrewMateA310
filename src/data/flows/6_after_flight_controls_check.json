{
  "id": "after_flight_controls_check",
  "name": "Taxi",
  "steps": [
    {
      "label": "Elevator Full Up",
      "read": "(A:ELEVATOR DEFLECTION PCT, Percent Over 100)",
      "on": "-16384 (>K:ELEVATOR_SET)",
      "expect": 0.59,
      "sound_after_execute": "full_up.ogg"
    },
    {
      "label": "Elevator Neutral",
      "read": "(A:ELEVATOR DEFLECTION PCT, Percent Over 100)",
      "on": "0 (>K:ELEVATOR_SET)",
      "expect": 0
    },
    {
      "label": "Elevator Full Down",
      "read": "(A:ELEVATOR DEFLECTION PCT, Percent Over 100)",
      "on": "16384 (>K:ELEVATOR_SET)",
      "expect": -0.93,
      "sound_after_execute": "full_down.ogg"
    },
    {
      "label": "Elevator Neutral",
      "read": "(A:ELEVATOR DEFLECTION PCT, Percent Over 100)",
      "on": "0 (>K:ELEVATOR_SET)",
      "expect": 0,
      "sound_after_execute": "neutral.ogg"
    },
    {
      "label": "Aileron Full Left",
      "read": "(A:AILERON LEFT DEFLECTION PCT, Percent Over 100)",
      "on": "16383 (>K:AILERON_SET)",
      "expect": -0.75,
      "sound_after_execute": "full_left.ogg"
    },
    {
      "label": "Aileron Neutral",
      "read": "(A:AILERON POSITION, Percent Over 100)",
      "on": "0 (>K:AILERON_SET)",
      "expect": 0
    },
    {
      "label": "Aileron Full Right",
      "read": "(A:AILERON RIGHT DEFLECTION PCT, Percent Over 100)",
      "on": "-16384 (>K:AILERON_SET)",
      "expect": 0.75,

      "sound_after_execute": "full_right.ogg"
    },
    {
      "label": "Aileron Neutral",
      "read": "(A:AILERON POSITION, Percent Over 100)",
      "on": "0 (>K:AILERON_SET)",
      "expect": 0,
      "sound_after_execute": "neutral.ogg"
    },
    {
      "label": "Close FCTL ECAM",
      "read": "(L:PUSH_ECAM_FCTL)",
      "on": "1 (>L:PUSH_ECAM_FCTL)",
      "expect": 1
    },
    {
      "label": "Arm profile mode",
      "read": "(L:AP3_BUTTON)",
      "on": "1 (>L:AP3_BUTTON)",
      "expect": 1
    },
    {
      "label": "Arm nav mode",
      "read": "(L:A310_FCU_MANAGED_HEADING_BUTTON)",
      "on": "1 (>L:A310_FCU_MANAGED_HEADING_BUTTON)",
      "expect": 1
    },
    {
      "label": "Weather radar on",
      "read": "(L:A310_WXR_SYS)",
      "on": "0 (>L:A310_WXR_SYS)",
      "expect": 0
    },
    {
      "label": "Takeoff config test",
      "read": "(L:A310_TAKEOFF_CONFIG_PRESSED)",
      "on": "1 (>L:A310_TAKEOFF_CONFIG_PRESSED)",
      "expect": 1,
      "hold_ms": 2000
    }
  ]
}
