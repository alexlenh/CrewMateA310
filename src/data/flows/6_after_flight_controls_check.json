{
  "id": "after_flight_controls_check",
  "name": "After Flight Controls Check",
  "steps": [
    {
      "label": "Arm profile mode",
      "read": "(L:AP3_BUTTON)",
      "on": "1 (>L:AP3_BUTTON)",
      "expect": 1
    },
    {
      "label": "Arm nav mode",
      "read": "(L:A310_FCU_MANAGED_HEADING_BUTTON)",
      "on": "1 (>L:A310_FCU_MANAGED_HEADING_BUTTON)",
      "expect": 1
    },
    {
      "label": "Weather radar on",
      "read": "(L:A310_WXR_SYS)",
      "on": "0 (>L:A310_WXR_SYS)",
      "expect": 0
    },
    {
      "label": "Takeoff config test",
      "read": "(L:A310_TAKEOFF_CONFIG_PRESSED)",
      "on": "1 (>L:A310_TAKEOFF_CONFIG_PRESSED)",
      "expect": 1,
      "hold_ms": 2000
    }
  ]
}
