{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "crewmatea310",
  "version": "0.3.0",
  "identifier": "crewmatea310",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Crewmate INI A310",
        "width": 360,
        "height": 280,
        "minWidth": 360,
        "minHeight": 280,
        "maximizable": false,
        "fullscreen": false,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi"],
    "externalBin": ["bin/copilot_speech"],
    "resources": ["sounds", "bin/grammar.xml", "Trainer"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzQkJDNUU5MjY1QjE1ODIKUldTQ0ZWc202Y1c3c3oyT1hnNlgzd0lrVDFvdTZXL3dqWEViaDBMdEQ3Yk1uZ3owZnB0OTRLb1EK",
      "endpoints": ["https://github.com/CrewMate-Flight-Sim/CrewMateA310/releases/latest/download/latest.json"]
    }
  }
}
