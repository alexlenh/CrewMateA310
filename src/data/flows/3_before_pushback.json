{
  "id": "before_pushback",
  "name": "Before Pushback",
  "steps": [
    {
      "label": "SET MCDU",
      "read": "(L:A310_MCDU2_FPLAN)",
      "on": "1 (>L:A310_MCDU2_FPLAN)",
      "expect": 1
    },
    {
      "label": "Beacon on",
      "read": "(L:A310_BEACON_LIGHT_SWITCH)",
      "on": "1 (>L:A310_BEACON_LIGHT_SWITCH)",
      "expect": 1
    },
    {
      "label": "TCAS Set",
      "read": "(L:A310_tcas_mode_pedestal)",
      "on": "1 (>L:A310_tcas_mode_pedestal)",
      "expect": 1
    },
    {
      "label": "Remove Chocks",
      "read": "(L:A310_CHOCKS_ENABLED)",
      "on": "0 (>L:A310_CHOCKS_ENABLED)",
      "expect": 0
    }
  ]
}
