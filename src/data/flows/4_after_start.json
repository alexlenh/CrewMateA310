{
  "id": "after_start",
  "name": "After Start",
  "steps": [
    {
      "label": "APU Bleed off",
      "read": "(L:A310_apu_bleed)",
      "on": "0 (>L:A310_apu_bleed)",
      "expect": 0
    },
    {
      "label": "APU off",
      "read": "(L:A310_apu_master_switch)",
      "on": "0 (>L:A310_apu_master_switch)",
      "expect": 0
    },
    {
      "label": "Flaps",
      "read": "(A:FLAPS HANDLE INDEX,Number)",
      "on": "(>K:FLAPS_{flaps})",
      "expect": "{flaps}",
      "only_if": {
        "option": "takeoff.antiIce",
        "one_of": ["off"]
      }
    },
    {
      "label": "Ground Spoilers",
      "read": "(L:A310_SPOILERS_ARMED)",
      "on": "1 (>K:SPOILERS_ARM_SET)",
      "expect": 1
    },
    {
      "label": "Reset Rudder Trim",
      "read": "(L:A310_RESET_RUDDER_TRIM_COMMAND)",
      "on": "1 (>L:A310_RESET_RUDDER_TRIM_COMMAND)",
      "expect": 1,
      "skip_verify": true
    },
    {
      "label": "Pitch trim",
      "read": "(L:ELEV_TRIM_RATIO)",
      "on": "{pitch_trim_cmd}",
      "expect": "{pitch_trim_expect}"
    }
  ]
}
