{
  "id": "thr_red",
  "name": "After Takeoff part 1",
  "steps": [
    {
      "label": "Gear neutral",
      "read": "(L:A310_GEAR_HANDLE_STATUS)",
      "on": "1 (>L:A310_GEAR_HANDLE_STATUS)",
      "expect": 1,
      "sound_on_execute": "gear_neutral.ogg"
    },
    {
      "label": "Ground Spoilers",
      "read": "(L:A310_SPOILERS_ARMED)",
      "on": "1 (>K:SPOILERS_ARM_OFF)",
      "expect": 0,
      "skip_verify": true
    },
    {
      "label": "Takeoff Wheel Light",
      "read": "(L:A310_TAXI_LIGHTS_SWITCH)",
      "on": "2 (>L:A310_TAXI_LIGHTS_SWITCH)",
      "expect": 2
    },
    {
      "label": "Runway turnoff Light",
      "read": "(L:A310_RWY_TURNOFF_L_SWITCH)",
      "on": "0 (>L:A310_RWY_TURNOFF_L_SWITCH)",
      "expect": 0,
      "skip_delay": true
    },
    {
      "label": "Runway turnoff Light",
      "read": "(L:A310_RWY_TURNOFF_R_SWITCH)",
      "on": "0 (>L:A310_RWY_TURNOFF_R_SWITCH)",
      "expect": 0
    },
    {
      "label": "Pack 1",
      "read": "(L:A300_PACK1_BUTTON)",
      "on": "1 (>L:A300_PACK1_BUTTON)",
      "expect": 1,
      "sound_after_execute": "pack_1_on.ogg"
    },
    {
      "label": "Chrono",
      "read": "(L:A300DR_CHRONO_STATE_FO)",
      "on": "2 (>L:A300DR_CHRONO_STATE_FO)",
      "expect": 2
    }
  ]
}
