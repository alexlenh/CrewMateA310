      "expect": 0
    },
    {
      "label": "Emer light disarm",
      "read": "(L:A310_EMER_EXIT_SWITCH)",
      "on": "2 (>L:A310_EMER_EXIT_SWITCH)",
      "expect": 2
    },
    {
      "label": "Batteries off",
      "read": "(L:A310_BAT1_ON)",
      "on": "0 (>L:A310_BAT1_ON)",
      "expect": 0
    },
    {
      "label": "Batteries off",
      "read": "(L:A310_BAT2_ON)",
      "on": "0 (>L:A310_BAT2_ON)",
      "expect": 0
    },
    {
      "label": "Batteries off",
      "read": "(L:A310_BAT3_ON)",
      "on": "0 (>L:A310_BAT3_ON)",
      "expect": 0
