{
  "id": "shutdown",
  "name": "Shutdown",
  "steps": [
    {
      "label": "Engine 1 Anti Ice",
      "read": "(L:A310_ENG_ANTI_ICE1)",
      "on": "0 (L:A310_ENG_ANTI_ICE1)",
      "expect": 0,
      "skip_delay": true
    },
    {
      "label": "Engine 2 Anti Ice",
