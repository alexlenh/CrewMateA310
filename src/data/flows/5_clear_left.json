{
  "id": "clear_left",
  "name": "Clear Left",
  "sound_start": "clear_right.ogg",
  "steps": [
    {
      "label": "Nose Wheel Light",
      "read": "(L:A310_TAXI_LIGHTS_SWITCH)",
      "on": "1 (>L:A310_TAXI_LIGHTS_SWITCH)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Runway turnoff Light",
      "read": "(L:A310_RWY_TURNOFF_L_SWITCH)",
      "on": "1 (>L:A310_RWY_TURNOFF_L_SWITCH)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Runway turnoff Light",
      "read": "(L:A310_RWY_TURNOFF_R_SWITCH)",
      "on": "1 (>L:A310_RWY_TURNOFF_R_SWITCH)",
      "expect": 1,
      "only_if": {
        "option": "settings.lightsControlMode",
        "one_of": ["virtual"]
      }
    },
    {
      "label": "Elapsed time start",
      "read": "(L:A310_ET_TOGGLE_BUTTON_FO)",
      "on": "1 (>L:A310_ET_TOGGLE_BUTTON_FO)",
      "expect": 1
    }
  ]
}
