{
  "id": "cockpit_prep",
  "name": "Cockpit Preparation",
  "steps": [
    {
      "label": "Cockpit lights on",
      "read": "(L:A310_POTENTIOMETER_28)",
      "on": "85 (>L:A310_POTENTIOMETER_28)",
      "expect": 85,
      "only_if": {
        "read": "(E:TIME OF DAY)",
        "one_of": [0, 2, 3]
      }
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_OUTER_TANK1_LEFT)",
      "on": "1 (>L:A310_OUTER_TANK1_LEFT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_OUTER_TANK2_LEFT)",
      "on": "1 (>L:A310_OUTER_TANK2_LEFT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_OUTER_TANK1_RIGHT)",
      "on": "1 (>L:A310_OUTER_TANK1_RIGHT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_OUTER_TANK2_RIGHT)",
      "on": "1 (>L:A310_OUTER_TANK2_RIGHT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_INNER_TANK1_LEFT)",
      "on": "1 (>L:A310_INNER_TANK1_LEFT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_INNER_TANK1_RIGHT)",
      "on": "1 (>L:A310_INNER_TANK1_RIGHT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_INNER_TANK2_RIGHT)",
      "on": "1 (>L:A310_INNER_TANK2_RIGHT)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_CENTER_TANK1)",
      "on": "1 (>L:A310_CENTER_TANK1)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_CENTER_TANK2)",
      "on": "1 (>L:A310_CENTER_TANK2)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_TRIM_TANK1)",
      "on": "1 (>L:A310_TRIM_TANK1)",
      "expect": 1
    },
    {
      "label": "Fuel pumps on",
      "read": "(L:A310_TRIM_TANK2)",
      "on": "1 (>L:A310_TRIM_TANK2)",
      "expect": 1
    }
  ]
}
