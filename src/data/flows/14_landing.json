{
  "id": "landing",
  "name": "Landing",
  "sound_start": "cabin_landing.ogg",
  "steps": [
    {
      "label": "Ground Spoilers",
      "read": "(L:A310_SPOILERS_ARMED)",
      "on": "1 (>K:SPOILERS_ARM_SET)",
      "expect": 1
    },
    {
      "label": "Auto Brake",
      "read": "(L:A310_AUTOBRAKE_LEVEL)",
      "on": "{autobrake_set}",
      "expect": "{autobrake_expect}"
    },
    {
      "label": "Wing anti ice",
      "read": "(L:A310_WING_ANTI_ICE)",
      "on": "0 (>L:A310_WING_ANTI_ICE)",
      "expect": 0
    },
    {
      "label": "Nose Wheel Light",
      "read": "(L:A310_TAXI_LIGHTS_SWITCH)",
      "on": "1 (>L:A310_TAXI_LIGHTS_SWITCH)",
      "expect": 1
    },
    {
      "label": "Runway turnoff Light",
      "read": "(L:A310_RWY_TURNOFF_L_SWITCH)",
      "on": "1 (>L:A310_RWY_TURNOFF_L_SWITCH)",
      "expect": 1,
      "skip_delay": true
    },
    {
      "label": "Runway turnoff Light",
      "read": "(L:A310_RWY_TURNOFF_R_SWITCH)",
      "on": "1 (>L:A310_RWY_TURNOFF_R_SWITCH)",
      "expect": 1
    }
  ]
}
